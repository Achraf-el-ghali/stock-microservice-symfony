<form method="post" action="{{ path('app_promotion_delete', {'id': promotion.id}) }}" style="display:inline-block;" onsubmit="return confirm('Are you sure you want to delete this promotion?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ promotion.id) }}">
    <button class="btn btn-danger btn-xs shadow-sm" title="Delete">
        <i class="fas fa-trash"></i>
    </button>
</form>
