{% extends 'adminlte.html.twig' %}

{% block title %}Stock Management{% endblock %}
{% block page_title %}Stock Management{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12">
        <div class="card card-outline card-primary shadow-sm">
            <div class="card-header">
                <h3 class="card-title">Stock Inventory Management</h3>
                <div class="card-tools">
                    <form method="post" action="{{ path('app_stock_import') }}" style="display:inline-block;" class="mr-2">
                        <button type="submit" class="btn btn-outline-info btn-sm">
                            <i class="fas fa-file-import"></i> Import stock.csv
                        </button>
                    </form>
                    <a href="{{ path('app_stock_export') }}" class="btn btn-outline-secondary btn-sm mr-2">
                        <i class="fas fa-file-export"></i> Export CSV
                    </a>
                    <a href="{{ path('app_stock_new') }}" class="btn btn-success btn-sm">
                        <i class="fas fa-plus"></i> Add New Stock
                    </a>
                </div>
            </div>
            <!-- /.card-header -->
            <div class="card-body">
                <table id="stockTable" class="table table-professional responsive nowrap" style="width:100%">
                    <thead>
                        <tr>
                            <th>SKU</th>
                            <th>Status</th>
                            <th>Price</th>
                            <th>Final Price</th>
                            <th>Qty</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for stock in stocks %}
                        <tr>
                            <td>
                                <span class="text-bold"><i class="fas fa-barcode mr-2 text-primary"></i>{{ stock.sku }}</span>
                            </td>
                            <td>
                                <span class="badge {{ stock.isActive ? 'bg-success' : 'bg-secondary' }} shadow-sm">
                                    <i class="fas {{ stock.isActive ? 'fa-check-circle' : 'fa-times-circle' }} mr-1"></i>
                                    {{ stock.isActive ? 'Active' : 'Inactive' }}
                                </span>
                            </td>
                            <td>{{ stock.price|number_format(2) }} €</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <span class="text-success text-bold mr-2">{{ stock.finalPrice|number_format(2) }} €</span>
                                    {% if stock.promotions|length > 0 %}
                                        <span class="badge badge-info" title="{{ stock.promotions|length }} active promo">
                                            <i class="fas fa-percentage"></i>
                                        </span>
                                    {% endif %}
                                </div>
                            </td>
                            <td>{{ stock.quantity }}</td>
                            <td>
                                <div class="btn-group">
                                    <a href="{{ path('app_stock_edit', {'id': stock.id}) }}" class="btn btn-info btn-xs shadow-sm" title="Edit">
                                        <i class="fas fa-pencil-alt"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_stock_sync', {'id': stock.id}) }}" style="display:inline-block;">
                                        <button class="btn btn-warning btn-xs shadow-sm" title="Sync Kafka">
                                            <i class="fas fa-sync"></i>
                                        </button>
                                    </form>
                                    {{ include('stock/_delete_form.html.twig') }}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            <!-- /.card-body -->
        </div>
        <!-- /.card -->
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    $(function () {
        $("#stockTable").DataTable({
            "responsive": true,
            "lengthChange": true,
            "autoWidth": false,
            "pageLength": 10,
            "order": [[0, "asc"]],
            "language": {
                "search": "Search SKU:",
                "paginate": {
                    "previous": "Prev",
                    "next": "Next"
                }
            }
        });
    });
</script>
{% endblock %}
