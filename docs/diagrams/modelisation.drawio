        <mxCell id="sec" value="&lt;b&gt;Système de Sécurité (ASP.NET Core Identity)&lt;/b&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;+ chiffrerMotDePasse() : void&lt;br&gt;+ genererToken(user) : Token&lt;br&gt;+ securiserSession() : void&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="520" y="90" width="360" height="140" as="geometry"/></mxCell>

