        <mxCell id="pay" value="&lt;b&gt;Paiement (Payment)&lt;/b&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;- ID_Commande : string&lt;br&gt;- Montant : decimal&lt;br&gt;- Devise : string (MAD)&lt;br&gt;- Statut : Enum (Réussi, Échoué, En cours)&lt;br&gt;- DatePaiement : DateTime&lt;/div&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;+ initier() : void&lt;br&gt;+ confirmer() : void&lt;br&gt;+ rembourser() : void&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="440" y="100" width="320" height="260" as="geometry"/></mxCell>
