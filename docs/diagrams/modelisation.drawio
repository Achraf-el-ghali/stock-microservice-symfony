        <mxCell id="lot" value="&lt;b&gt;StockLot&lt;/b&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;- id : int&lt;br&gt;- sku : string&lt;br&gt;- quantityInitial : int&lt;br&gt;- quantityRemaining : int&lt;br&gt;- purchasePrice : float&lt;br&gt;- sellingPrice : float&lt;br&gt;- dateEntry : DateTime&lt;/div&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;+ isExhausted() : bool&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="100" y="100" width="260" height="240" as="geometry"/></mxCell>

        <mxCell id="stk" value="&lt;b&gt;Stock&lt;/b&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;- id : int&lt;br&gt;- sku : string {unique}&lt;br&gt;- quantity : int&lt;br&gt;- price : float&lt;br&gt;- isActive : bool&lt;/div&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;+ getFinalPrice() : float&lt;br&gt;+ isInStock() : bool&lt;br&gt;+ getStockStatus() : string&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="520" y="100" width="280" height="240" as="geometry"/></mxCell>

        <mxCell id="pr" value="&lt;b&gt;Promotion&lt;/b&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;- id : int&lt;br&gt;- code : string&lt;br&gt;- type : string&lt;br&gt;- value : float&lt;br&gt;- startDate : DateTime&lt;br&gt;- endDate : DateTime&lt;/div&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;+ isActive() : bool&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="960" y="100" width="260" height="230" as="geometry"/></mxCell>

        <mxCell id="mgr" value="&lt;b&gt;StockManager&lt;/b&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;- repository : StockRepository&lt;br&gt;- producer : KafkaProducer&lt;/div&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;+ updateStock(sku, qty, source) : void&lt;br&gt;+ handleSale(sku, qty) : void&lt;br&gt;+ handleReturn(sku, qty) : void&lt;br&gt;+ getStockBySku(sku) : Stock&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="460" y="460" width="340" height="220" as="geometry"/></mxCell>

        <mxCell id="kfk" value="&lt;b&gt;KafkaProducer&lt;/b&gt;&lt;hr size=1&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;+ publishStockUpdate(sku, qty) : void&lt;br&gt;+ publishPromotion(promo) : void&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="960" y="500" width="280" height="140" as="geometry"/></mxCell>

        <mxCell id="ctl" value="&lt;b&gt;StockController&lt;/b&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;- manager : StockManager&lt;/div&gt;&lt;hr size=1&gt;&lt;div align='left'&gt;+ update(sku, request) : Response&lt;br&gt;+ getStocks() : Response&lt;br&gt;+ getHistory(sku) : Response&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="460" y="740" width="340" height="160" as="geometry"/></mxCell>

