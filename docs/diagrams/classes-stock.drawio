        <mxCell id="note1" value="&lt;font color='#008800'&gt;&lt;i&gt;Un Stock peut avoir plusieurs lots&lt;br&gt;d'approvisionnement (FIFO)&lt;/i&gt;&lt;/font&gt;" style="text;html=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="60" y="310" width="200" height="40" as="geometry"/></mxCell>
